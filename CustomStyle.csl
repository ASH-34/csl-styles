<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" version="1.0">
  <info>
    <title>Custom Exact Journal Style</title>
    <id>http://www.zotero.org/styles/custom-exact-journal</id>
    <author>
      <name>Generated by ChatGPT</name>
    </author>
    <category citation-format="author-date"/>
  </info>

  <!-- Macro for authors in uppercase with initials -->
  <macro name="author">
    <names variable="author">
      <name and="text" initialize-with="." name-as-sort-order="all">
        <name-part name="family" text-case="uppercase"/>
        <name-part name="given" initialize-with="true"/>
      </name>
    </names>
  </macro>

  <!-- Macro for article title -->
  <macro name="title">
    <text variable="title" font-style="normal"/>
  </macro>

  <!-- Macro for journal info: Journal, Volume(Issue), Page, Year -->
  <macro name="journal-info">
    <text variable="container-title"/>
    <text variable="volume" prefix=", "/>
    <text variable="issue" prefix=" (" suffix=")"/>
    <text variable="page" prefix=", "/>
    <text variable="issued" form="year" prefix=", "/>
  </macro>

  <!-- Bibliography layout -->
  <bibliography>
    <layout delimiter=" ">
      <text macro="author"/>
      <text macro="title" prefix=" "/>
      <text macro="journal-info" prefix=" "/>
    </layout>
  </bibliography>

  <!-- Citation layout (in-text references) -->
  <citation>
    <layout>
      <text macro="author"/>
      <text macro="title" prefix=" "/>
      <text macro="journal-info" prefix=" "/>
    </layout>
  </citation>
</style>